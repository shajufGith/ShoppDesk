// Prisma schema for ShopDesk
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  MANAGER
  EMPLOYEE
}

enum TransactionType {
  OPENING
  SALES
  COLLECTION
}

enum CustomerIdMode {
  AUTO
  MANUAL
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Business {
  id        String   @id @default(cuid())
  name      String
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  customers        Customer[]
  segments         CustomerSegment[]
  areas            CustomerArea[]
  transactions     Transaction[]
  settings         AppSettings?
}

model User {
  id           String   @id @default(cuid())
  name         String
  username     String   @unique
  passwordHash String
  role         Role
  designation  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business     Business @relation(fields: [businessId], references: [id])
  businessId   String

  // Relations
  customersCreated Customer[]    @relation("CustomerCreatedBy")
  transactions     Transaction[] @relation("TransactionCreatedBy")
}

model CustomerSegment {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business   Business @relation(fields: [businessId], references: [id])
  businessId String

  customers Customer[]

  @@unique([businessId, name])
}

model CustomerArea {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business   Business @relation(fields: [businessId], references: [id])
  businessId String

  customers Customer[]

  @@unique([businessId, name])
}

model Customer {
  id             String  @id @default(cuid())
  customerNumber String  // unique per business
  name           String
  address1       String
  address2       String?
  mobile         String
  isActive       Boolean @default(true)

  business   Business @relation(fields: [businessId], references: [id])
  businessId String

  segment   CustomerSegment? @relation(fields: [segmentId], references: [id])
  segmentId String?

  area      CustomerArea? @relation(fields: [areaId], references: [id])
  areaId    String?

  createdBy   User   @relation("CustomerCreatedBy", fields: [createdById], references: [id])
  createdById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions Transaction[]

  @@unique([businessId, customerNumber])
}

model Transaction {
  id     String          @id @default(cuid())
  type   TransactionType
  amount Decimal         @db.Decimal(12, 2)
  date   DateTime        @default(now())
  note   String?

  business   Business @relation(fields: [businessId], references: [id])
  businessId String

  customer   Customer @relation(fields: [customerId], references: [id])
  customerId String

  createdBy   User   @relation("TransactionCreatedBy", fields: [createdById], references: [id])
  createdById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Stores settings per business
model AppSettings {
  id             String         @id @default(cuid())
  customerIdMode CustomerIdMode @default(AUTO)
  customerPrefix String         @default("CUST")   // prefix for auto mode
  nextAutoNumber Int            @default(1)        // next auto-increment number
  updatedAt      DateTime       @updatedAt

  business       Business       @relation(fields: [businessId], references: [id])
  businessId     String         @unique
}
