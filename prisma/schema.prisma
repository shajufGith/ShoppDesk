generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Business {
  id           String            @id @default(cuid())
  name         String
  address      String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  settings     AppSettings?
  customers    Customer[]
  areas        CustomerArea[]
  segments     CustomerSegment[]
  transactions Transaction[]
  users        User[]
}

model User {
  id               String        @id @default(cuid())
  name             String
  username         String        @unique
  passwordHash     String
  role             Role
  designation      String?
  isActive         Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  businessId       String
  customersCreated Customer[]    @relation("CustomerCreatedBy")
  transactions     Transaction[] @relation("TransactionCreatedBy")
  business         Business      @relation(fields: [businessId], references: [id])
}

model CustomerSegment {
  id         String     @id @default(cuid())
  name       String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  businessId String
  customers  Customer[]
  business   Business   @relation(fields: [businessId], references: [id])

  @@unique([businessId, name])
}

model CustomerArea {
  id         String     @id @default(cuid())
  name       String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  businessId String
  customers  Customer[]
  business   Business   @relation(fields: [businessId], references: [id])

  @@unique([businessId, name])
}

model Customer {
  id             String           @id @default(cuid())
  customerNumber String
  name           String
  address1       String
  address2       String?
  mobile         String
  isActive       Boolean          @default(true)
  businessId     String
  segmentId      String?
  areaId         String?
  createdById    String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  area           CustomerArea?    @relation(fields: [areaId], references: [id])
  business       Business         @relation(fields: [businessId], references: [id])
  createdBy      User             @relation("CustomerCreatedBy", fields: [createdById], references: [id])
  segment        CustomerSegment? @relation(fields: [segmentId], references: [id])
  transactions   Transaction[]

  @@unique([businessId, customerNumber])
}

model Transaction {
  id          String          @id @default(cuid())
  type        TransactionType
  amount      Decimal         @db.Decimal(12, 2)
  date        DateTime        @default(now())
  note        String?
  businessId  String
  customerId  String
  createdById String
  paymentMode PaymentMode?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  business    Business        @relation(fields: [businessId], references: [id])
  createdBy   User            @relation("TransactionCreatedBy", fields: [createdById], references: [id])
  customer    Customer        @relation(fields: [customerId], references: [id])
}

model AppSettings {
  id             String         @id @default(cuid())
  customerIdMode CustomerIdMode @default(AUTO)
  customerPrefix String         @default("CUST")
  nextAutoNumber Int            @default(1)
  updatedAt      DateTime       @updatedAt
  businessId     String         @unique
  business       Business       @relation(fields: [businessId], references: [id])
}

enum Role {
  MANAGER
  EMPLOYEE
}

enum TransactionType {
  OPENING
  SALES
  COLLECTION
}

enum CustomerIdMode {
  AUTO
  MANUAL
}

enum PaymentMode {
  CASH
  GPAY
  ADJUSTMENT
  OTHERS
}
